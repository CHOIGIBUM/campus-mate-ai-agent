# Runtime
CAMPUS_MATE_ENV=development
CAMPUS_MATE_TIMEZONE=Asia/Seoul
CAMPUS_MATE_STORAGE_BACKEND=notion
CAMPUS_MATE_LOG_LEVEL=INFO

# Notion — use the data source ID shown in Notion's "Manage data sources" menu.
NOTION_API_KEY=
NOTION_DATA_SOURCE_ID=
# Optional fallback: if only a database container ID is provided, Campus Mate resolves its first data source.
NOTION_DATABASE_ID=
NOTION_DASHBOARD_URL=
NOTION_UPLOAD_POSTERS=true

# Slack — use a channel ID such as C0123456789, not a display name.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Optional vision pass. Any OpenAI-compatible vision endpoint can be used.
CAMPUS_MATE_VISION_API_KEY=
CAMPUS_MATE_VISION_BASE_URL=https://api.upstage.ai/v1
CAMPUS_MATE_VISION_MODEL=

# OCR / browser rendering
CAMPUS_MATE_ENABLE_OCR=true
CAMPUS_MATE_ENABLE_VISION=true
CAMPUS_MATE_OCR_LANGUAGES=kor+eng
CAMPUS_MATE_TESSERACT_CMD=

# Collection
CAMPUS_MATE_SOURCE_LIMIT=8
CAMPUS_MATE_REQUEST_TIMEOUT=20
CAMPUS_MATE_MAX_RETRIES=3

# Files
CAMPUS_MATE_DATA_DIR=data
CAMPUS_MATE_ARTIFACTS_DIR=artifacts
CAMPUS_MATE_PROFILE_PATH=data/user_profile.json
CAMPUS_MATE_LOCAL_STORE_PATH=data/opportunities.json
